FORGE_API_KEY=change-me-local-dev-key

# Docker Compose (builder em container): GID do grupo docker no host (Linux).
# Obter com: getent group docker | cut -d: -f3
# DOCKER_GID=999

# Postgres (serviço forge-postgres no docker-compose)
FORGE_POSTGRES_USER=forge
FORGE_POSTGRES_PASSWORD=change-me-postgres-password
FORGE_POSTGRES_DB=forge
